# ==========================================
# Be-chuda Project - Global .gitignore
# ==========================================

# 1. Dependency Directories (가장 무거운 패키지 폴더 제외)
node_modules
jspm_packages
web_modules

# 2. Next.js (프론트엔드 빌드 결과물 제외)
frontend.next
frontendout
frontendbuild

# 3. Nest.js (백엔드 빌드 결과물 및 TS 컴파일 파일 제외)
backenddist
backendout
backend.tsbuildinfo

# 4. Local Environment Variables (보안이 중요한 환경 변수 파일 제외 - 비밀번호 노출 방지)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend.env
frontend.env

# 5. OS & IDE-specific files (운영체제 및 VS Code 설정파일 제외)
.DS_Store
.idea
.vscode
.suo
.ntvs
.njsproj
.sln
.sw

# 6. Log Files (로그 파일 제외)
npm-debug.log
yarn-debug.log
yarn-error.log
logs
.log